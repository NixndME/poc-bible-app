# HPE Morpheus POC Bible — Environment Variables
# Copy this file to .env and fill in your values before running locally.
# .env is git-ignored. Never commit real credentials.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pocbible:changeme@localhost:5432/pocbible

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-this-to-a-random-64-char-hex-string
JWT_EXPIRY_HOURS=8

# ── Master admin bootstrap ────────────────────────────────────────────────────
# Used only on first startup to seed the admin account.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=changeme
ADMIN_NAME=Admin User

# ── Smartsheet integration ────────────────────────────────────────────────────
SMARTSHEET_API_KEY=your-smartsheet-api-key-here
SMARTSHEET_SHEET_ID=your-sheet-id-here

# ── Access control ────────────────────────────────────────────────────────────
PARTNER_EXPIRY_DAYS=183

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use * for local dev. Restrict to your domain(s) in production.
APP_CORS_ORIGINS=*

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to true only in QA/testing — enables a full DB wipe endpoint.
# NEVER set to true in production.
ALLOW_DB_CLEANUP=false
