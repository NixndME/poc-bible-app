# HPE Morpheus POC Bible — Air-gapped Environment
# Copy this file to .env.airgapped and fill in your values before running.
# .env.airgapped is git-ignored. Never commit with real values.
#
# Usage:
#   cp .env.airgapped.example .env.airgapped
#   # Edit .env.airgapped with your values
#   docker compose -f docker-compose.airgapped.yml up -d

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the local PostgreSQL container (only accessible inside Docker network)
POSTGRES_PASSWORD=changeme_local_db

# ── Application ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:changeme_local_db@db:5432/pocbible

# Generate a unique secret per deployment: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_with_secrets_token_hex_32
JWT_EXPIRY_HOURS=8

# ── SE / Admin login ──────────────────────────────────────────────────────────
# The SE uses these credentials to log into the dashboard if needed.
# The seed script uses ADMIN_EMAIL to create the SE user.
ADMIN_EMAIL=se@yourcompany.com
ADMIN_PASSWORD=changeme_strong_password
ADMIN_NAME=Local SE

# ── Smartsheet (intentionally disabled for air-gapped) ───────────────────────
# Leave these blank — disables all Smartsheet calls and the sync scheduler.
SMARTSHEET_API_KEY=
SMARTSHEET_SHEET_ID=

# ── Misc ──────────────────────────────────────────────────────────────────────
APP_CORS_ORIGINS=*
PARTNER_EXPIRY_DAYS=183
ALLOW_DB_CLEANUP=false
